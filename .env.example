# =====================================================================
# Excel2Tableau — Frontend environment configuration
# Copy to `.env`. Only variables prefixed with VITE_ are exposed to the
# client bundle. NEVER put secrets here.
# =====================================================================

# Base URL for the backend API. In dev, Vite proxies /api -> :8000,
# so the default relative path works without changes.
VITE_API_BASE_URL=/api/v1
